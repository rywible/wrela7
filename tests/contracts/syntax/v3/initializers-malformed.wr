module contracts.initializers_malformed

struct InvalidShape:
    @budget(bound=1)
    pub init(self):
        pass

struct DuplicateInitializers:
    init(mut self):
        pass
    init(mut self):
        pass

struct RemovedInitializer:
    fn __init__(mut self):
        pass

struct NestedInitializer:
    comptime if true:
        init(mut self):
            pass
